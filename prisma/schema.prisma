// Laguna Café POS System - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Users =====
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  name         String
  role         String   @default("CASHIER") // CASHIER | ADMIN
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  returns      Return[]
  payments     EmployeePayment[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== Tables =====
model Table {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "ترابيزة 1"
  number    Int      @unique
  qrToken   String   @unique
  seats     Int      @default(4)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders    Order[]
}

// ===== Menu =====
model Category {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  icon      String?
  coverUrl  String?
  sortOrder Int      @default(0)
  items     MenuItem[]
}

model MenuItem {
  id         String   @id @default(cuid())
  name       String
  nameAr     String
  price      Float
  categoryId String
  imageUrl   String?
  available  Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

// ===== Orders / Invoices =====
model Order {
  id            String   @id @default(cuid())
  invoiceNumber Int      @unique
  tableId       String?
  cashierId     String
  status        String   @default("PENDING") // PENDING | PAID | CANCELLED
  paymentMethod String?  // CASH | VISA | MASTER | ONLINE
  subtotal      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  discountRate  Float    @default(0)
  discountAmount Float   @default(0)
  total         Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
  cancelledBy   String?
  cancelReason  String?

  table         Table?   @relation(fields: [tableId], references: [id])
  cashier       User     @relation(fields: [cashierId], references: [id])
  items         OrderItem[]
  returns       Return[]

  @@index([cashierId])
  @@index([tableId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String
  price      Float
  quantity   Int      @default(1)
  total      Float
  notes      String?

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  returnItems ReturnItem[]
}

// ===== Returns =====
model Return {
  id           String   @id @default(cuid())
  orderId      String
  returnedById String
  reason       String
  totalRefund  Float    @default(0)
  createdAt    DateTime @default(now())

  order        Order    @relation(fields: [orderId], references: [id])
  returnedBy   User     @relation(fields: [returnedById], references: [id])
  items        ReturnItem[]
}

model ReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  orderItemId String
  name        String
  price       Float
  quantity    Int
  total       Float

  return      Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

// ===== Employees (Staff) =====
model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("موظف") // role/title
  phone     String?
  salary    Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  attendance  Attendance[]
  payments    EmployeePayment[]
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String   @default("PRESENT") // PRESENT | ABSENT | LATE | HALF_DAY
  notes      String?
  createdAt  DateTime @default(now())

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
}

model EmployeePayment {
  id         String   @id @default(cuid())
  employeeId String
  amount     Float
  date       DateTime @default(now())
  notes      String?
  paidById   String

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  paidBy     User     @relation(fields: [paidById], references: [id])
}

// ===== Settings =====
model Setting {
  id    String @id
  key   String @unique
  value String
}
